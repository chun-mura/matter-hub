# --- 推奨（開発）: 直 fetch せず Vite プロキシで同一オリジンにする ---
# VITE_API_BASE_URL は未設定のまま（または空）。
# プロキシ先（Docker Compose の api コンテナへ向ける例）
# VITE_API_PROXY_TARGET=http://api:8000
# ホストで API が 8000 のとき
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
# ホストで API が 8001 のとき
# VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# --- オプション: ブラウザから API へ直 fetch（別オリジン。API 側 CORS が必須）---
# VITE_API_BASE_URL=http://127.0.0.1:8000
